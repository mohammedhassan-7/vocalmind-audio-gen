# ─────────────────────────────────────────────────────────────────────────────
# TTS Audio Generator — example environment configuration.
#
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env       # macOS / Linux
#   copy .env.example .env     # Windows
#
# .env is gitignored. Never commit real keys, project IDs, or paths to it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Credentials ─────────────────────────────────────────────────────────────
# Directory containing either:
#   - a Vertex AI service-account JSON  (preferred — uses GCP credits)
#   - api_key.txt with a Google AI Studio key  (fallback — AI Studio billing)
#
# Defaults to ./keys/ inside the repo. Set this to an absolute path outside
# the repo for stricter credential isolation.
TTS_KEY_DIR=./keys

# ── Vertex AI (used only when a service-account JSON is found) ──────────────
# Your GCP project ID and the region you deployed the Gemini TTS model in.
TTS_PROJECT_ID=your-gcp-project-id
TTS_LOCATION=us-central1

# ── Optional: explicit AI Studio key inline ─────────────────────────────────
# If you'd rather not put a key file in TTS_KEY_DIR, uncomment and set:
# GOOGLE_API_KEY=your-ai-studio-key
